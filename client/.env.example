# ── Clerk ─────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys → Publishable Key
# Starts with pk_test_ (dev) or pk_live_ (prod)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend Socket / API URL ──────────────────────────────────────────────────
# For local dev:
VITE_SOCKET_URL=http://localhost:1000
# For production (your Render URL):
# VITE_SOCKET_URL=https://your-nexchat-backend.onrender.com
